# Copy to .env.local and fill in. Never commit .env.local.
# OpenRouter: https://openrouter.ai/keys — use separate keys per model if you prefer.

OPENROUTER_NEMOTRON_KEY=
OPENROUTER_KIMI_KEY=

# Optional overrides (defaults work on OpenRouter)
# OPENROUTER_MODEL_NEMOTRON=nvidia/nemotron-3-super-120b-a12b
# OPENROUTER_MODEL_KIMI=moonshotai/kimi-k2.5

# Groq: https://console.groq.com/keys
GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile

# Used in OpenRouter HTTP-Referer header (match your dev port)
NEXT_PUBLIC_APP_URL=http://localhost:3001
